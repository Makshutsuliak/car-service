{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/clerk/(.*)",
      "dest": "/clerk/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    },
     {
      "src": "/public/(.*)",
      "dest": "/public/$1"
    }
  ],
  "outputDirectory": "dist"
}
